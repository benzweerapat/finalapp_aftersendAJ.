<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#CC1E1E1E"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/textSignalMain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RSRP -- dBm"
            android:textColor="#FDE68A"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSignalSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="LTE • PCI:- • RSRQ/SINR --"
            android:textColor="#E5E7EB"
            android:textSize="12sp" />

        <!-- Row: Points + Undo + Clear + Add -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textPointCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Points: 0"
                android:textColor="#93C5FD"
                android:textSize="12sp" />

            <!-- push buttons to the right -->
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btnClear"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:backgroundTint="#3B0E0E"
                android:text="🗑 Clear"
                android:textAllCaps="false"
                android:textColor="#FCA5A5"
                android:textSize="10sp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <Button
                android:id="@+id/btnUndo"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="↩ Undo"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <Button
                android:id="@+id/btnAddPoint"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#DC2626"
                android:text="📍 Add Point"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/textAddPointHint"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="0dp"
            android:text=""
            android:textColor="@android:color/transparent"
            android:textSize="0sp"
            android:visibility="gone" />

        <!-- Row: floor/height controls + toggle details -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btnCalibrate"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Floor --"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:minWidth="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <Button
                android:id="@+id/btnEditFloorHeight"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:enabled="true"
                android:layout_marginStart="6dp"
                android:text="Height 0.0 m"
                android:textAllCaps="false"
                android:textSize="10sp"
                android:minWidth="0dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp" />

            <Button
                android:id="@+id/btnToggleDetails"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:text="Show Details ▼"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:minWidth="0dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/detailsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>

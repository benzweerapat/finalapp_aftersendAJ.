<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#CC1E1E1E"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/textSignalMain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RSRP -- dBm"
            android:textColor="#FDE68A"
            android:textStyle="bold"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/textSignalSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LTE • PCI:- • RSRQ/SINR --"
            android:textColor="#E5E7EB"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/textPointCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Points: 0"
                android:textColor="#93C5FD"
                android:textSize="12sp"/>

            <Button
                android:id="@+id/btnToggleDetails"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="ขยายข้อมูล"
                android:textAllCaps="false"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnEndSurvey"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:text="End Survey"
                android:textAllCaps="false"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cellDetailContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/cellTechLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LTE"
                android:textColor="#00D1B2"
                android:textStyle="bold"
                android:textSize="20sp"/>

            <TextView
                android:id="@+id/cellOperatorValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Operator"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/cellRsrpValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="- dBm"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginTop="6dp"/>

            <TextView
                android:id="@+id/cellRsrqValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="- dB"
                android:textColor="#E0E0E0"/>

            <TextView
                android:id="@+id/cellArfcnValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ARFCN: -"
                android:textColor="#B0BEC5"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/cellFreqBwValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FREQ/BW: -"
                android:textColor="#B0BEC5"/>

            <TextView
                android:id="@+id/cellIdBlock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CELL: -"
                android:textColor="#B0BEC5"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/wifiDetailContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/wifiSsidValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SSID"
                android:textColor="#B0BEC5"
                android:textStyle="bold"
                android:textSize="18sp"/>

            <TextView
                android:id="@+id/wifiRssiValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="- dBm"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="6dp"/>

            <TextView android:id="@+id/wifiFreqValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Freq: -" android:textColor="#B0BEC5" />
            <TextView android:id="@+id/wifiChannelValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Channel: -" android:textColor="#B0BEC5" />
            <TextView android:id="@+id/wifiBwValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BW: -" android:textColor="#B0BEC5" />
            <TextView android:id="@+id/wifiLinkSpeedValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Link: -" android:textColor="#B0BEC5" />
            <TextView android:id="@+id/wifiSecurityValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Security: -" android:textColor="#B0BEC5" />
            <TextView android:id="@+id/wifiMacValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MAC: -" android:textColor="#B0BEC5" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>

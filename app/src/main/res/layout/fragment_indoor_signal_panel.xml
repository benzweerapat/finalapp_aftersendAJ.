<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#CC1E1E1E"
    app:cardCornerRadius="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/textSignalMain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RSRP -- dBm"
            android:textColor="#FDE68A"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textSignalSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="LTE • PCI:- • RSRQ/SINR --"
            android:textColor="#E5E7EB"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textPointCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Points: 0"
                android:textColor="#93C5FD"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnToggleDetails"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Show Details ▼"
                android:textAllCaps="false"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnEndSurvey"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginStart="6dp"
                android:text="End Survey"
                android:textAllCaps="false"
                android:textSize="12sp" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/detailsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

    </LinearLayout>
</androidx.cardview.widget.CardView>

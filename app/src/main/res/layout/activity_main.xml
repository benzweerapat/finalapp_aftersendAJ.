<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    tools:context=".MainActivity"
    android:fitsSystemWindows="true"
    >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnMenu"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="#FFFFFF"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView
                android:text="Drivetest App"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/currentModeText"
                android:text="Current Cellular ∙ GNSS"
                android:textColor="#22C55E"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/startHintText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#F87171"
                android:textSize="12sp"
                android:visibility="gone"
                android:layout_marginTop="6dp"/>
        </LinearLayout>





        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btnDriveMode"
                android:layout_width="124dp"
                android:minWidth="0dp"
                android:layout_height="40dp"
                android:text="GNSS"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textColor="#22C55E"
                android:drawableEnd="@drawable/ic_expand_more_16"
                android:drawablePadding="6dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#22C55E"
                app:strokeWidth="1dp"
                app:cornerRadius="20dp"
                android:layout_marginEnd="8dp"/>

            <!-- ปุ่มเลือกชั้น -->
            <Button
                android:id="@+id/btnSelectFloor"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="Floor --"
                android:textAllCaps="false"
                android:drawableEnd="@drawable/ic_expand_more_16"
                android:drawablePadding="6dp"
                android:textSize="12sp"
                android:textColor="#60A5FA"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                app:strokeColor="#3B82F6"
                app:strokeWidth="1dp"
                app:cornerRadius="20dp"
                android:layout_marginEnd="8dp"/>

            <!-- ปุ่ม START -->
            <Button
                android:id="@+id/saveCsvButton"
                android:layout_width="84dp"
                android:minWidth="0dp"
                android:layout_height="40dp"
                android:text="Start"
                android:textStyle="bold"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                app:cornerRadius="20dp"/>
        </LinearLayout>



    </LinearLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>

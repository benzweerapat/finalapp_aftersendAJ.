<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="24dp">

        <!-- ================= HEADER CARD ================= -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <ImageView
                        android:id="@+id/iconWifi"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_wifi"
                        app:tint="#00D1B2"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/wifiSsid"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SSID"
                        android:textColor="#B0BEC5"
                        android:textStyle="bold"
                        android:textSize="18sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end"
                    android:paddingEnd="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RSSI"
                        android:textColor="#80FFFFFF"
                        android:textSize="8sp"/>

                    <TextView
                        android:id="@+id/wifiRssi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="- dBm"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">



                    <ImageView
                        android:id="@+id/iconGps"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_gps"
                        android:tint="#FF5252"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ================= DETAIL CARD ================= -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:padding="16dp">

                <!-- LEFT -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FREQ"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/wifiFreq"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#FFFFFF"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CHANNEL"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/wifiChannel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#E0E0E0"/>

                    <TextView
                        android:id="@+id/wifiBw"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BW: —"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"/>
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#333333"
                    android:layout_marginHorizontal="8dp"/>

                <!-- RIGHT -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LINK SPEED"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/wifiLinkSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— Mbps"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="#E0E0E0"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SECURITY"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/wifiSecurity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#B0BEC5"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ================= WIFI EXTRA INFO (COMPAT MODE) ================= -->
        <!-- ================= WIFI EXTRA INFO (FREQ STYLE) ================= -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:padding="16dp">

                <!-- LEFT COLUMN -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MAC"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/wifiMac"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="14sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="STANDARD"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/wifiStandard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="#E0E0E0"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="TX / RX"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/wifiTxRx"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— / — Mbps"
                        android:textColor="#E0E0E0"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- DIVIDER -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="#333333"
                    android:layout_marginHorizontal="8dp"/>

                <!-- RIGHT COLUMN -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SIGNAL QUALITY"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/wifiSignalQual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— %"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:textSize="16sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SNR"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/wifiSnr"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— "
                        android:textColor="#E0E0E0"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SPEED"
                        android:textColor="#80FFFFFF"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/wifiSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="— Mbps"
                        android:textColor="#E0E0E0"
                        android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
        <!-- ================= LOCATION ================= -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Location"
                    android:textColor="#80FFFFFF"
                    android:textSize="11sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/latLngValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="— / —"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.95"
                        android:orientation="vertical"
                        android:paddingEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Altitude From Barometer"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/textFloor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Floor: -"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#22C55E" />
                        <TextView
                            android:id="@+id/textBaroEstimated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="estimated level"
                            android:textColor="#22C55E"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>


                        <TextView
                            android:id="@+id/textAltitude"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rel. Height: - m"
                            android:textColor="#E0E0E0"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/textPressure"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pressure: - hPa"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginBottom="8dp"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#2C2C2C"
                        android:layout_marginHorizontal="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.95"
                        android:orientation="vertical"
                        android:paddingStart="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Altitude From GPS"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/textGpsFloor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Floor: -"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#22C55E"/>
                        <TextView
                            android:id="@+id/textGpsEstimated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="estimated level"
                            android:textColor="#22C55E"
                            android:textSize="11sp"
                            android:layout_marginBottom="4dp"/>


                        <TextView
                            android:id="@+id/textGpsRelHeight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rel. Height: - m"
                            android:textColor="#E0E0E0"
                            android:textSize="12sp"/>

                        <TextView
                            android:id="@+id/textGpsAltitude"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Abs. Alt: - m"
                            android:textColor="#80FFFFFF"
                            android:textSize="11sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                    <View
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:background="#2C2C2C"
                        android:layout_marginHorizontal="8dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.1"
                        android:orientation="vertical"
                        android:paddingStart="8dp"
                        android:gravity="top">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCalibrate"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="30dp"
                            android:minHeight="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:text="Set Ground"
                            android:textAllCaps="false"
                            android:textSize="9sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:textColor="#60A5FA"
                            app:strokeColor="#3B82F6"
                            app:strokeWidth="1dp"
                            app:cornerRadius="20dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnReset"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="30dp"
                            android:minHeight="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:layout_marginTop="4dp"
                            android:text="Reset"
                            android:textAllCaps="false"
                            android:textSize="9sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:textColor="#F87171"
                            app:strokeColor="#EF4444"
                            app:strokeWidth="1dp"
                            app:cornerRadius="20dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEditFloorHeight"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="28dp"
                            android:minHeight="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:layout_marginTop="4dp"
                            android:text="Edit Height"
                            android:textAllCaps="false"
                            android:textSize="9sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:textColor="#9CA3AF"
                            app:strokeColor="#4B5563"
                            app:strokeWidth="1dp"
                            app:cornerRadius="16dp" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>




        <!-- ================= NEIGHBORS ================= -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NEIGHBOR WIFI"
            android:textStyle="bold"
            android:textColor="#80FFFFFF"
            android:textSize="12sp"
            android:paddingHorizontal="20dp"
            android:paddingBottom="8dp"/>


        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            app:cardBackgroundColor="#1E1E1E"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#333333"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="4dp">

                    <TextView android:text="#" android:layout_width="0dp" android:layout_weight="0.5" android:layout_height="wrap_content" android:gravity="center" android:textColor="#B0BEC5" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:text="SSID" android:layout_width="0dp" android:layout_weight="2" android:layout_height="wrap_content" android:gravity="center" android:textColor="#B0BEC5" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:text="Freq" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:gravity="center" android:textColor="#B0BEC5" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:text="RSSI" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:gravity="center" android:textColor="#B0BEC5" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:text="BW" android:layout_width="0dp" android:layout_weight="0.8" android:layout_height="wrap_content" android:gravity="center" android:textColor="#B0BEC5" android:textSize="11sp" android:textStyle="bold"/>
                    <TextView android:text="MAC" android:layout_width="0dp" android:layout_weight="2.5" android:layout_height="wrap_content" android:gravity="center" android:textColor="#B0BEC5" android:textSize="11sp" android:textStyle="bold"/>
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/wifiNeighborsRecycler"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>

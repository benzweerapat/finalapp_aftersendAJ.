<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <com.example.myapplication2.IndoorPlotImageView
        android:id="@+id/indoorMapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#0B1220" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="#AA111827"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnBrowseFloorPlan"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Browse Floor Plan"
            android:textAllCaps="false"
            android:textSize="11sp" />

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btnUndo"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Undo"
            android:textAllCaps="false"
            android:textSize="11sp" />
    </LinearLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/indoorSignalPanelContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="10dp" />

</FrameLayout>
